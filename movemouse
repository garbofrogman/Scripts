#!/usr/bin/env bash

# Dependencies:
# evemu
# inotify-tools
# getopt (util-linux)

# TODO: (maybe) choose a specific area of screen to keep active

# Mouse device. Set manualy if detection doesn't work. Use evemu-record to find your device.
dev=''

function detect_mouse() {
  local handler ev_mask=0 rel_mask=0 line
  while IFS= read -r line; do
    case "$line" in
    "H: Handlers="*)
      handler=${line#*Handlers=}
      ;;
    "B: EV="*)
      ev_mask=$((16#${line#B: EV=}))
      ;;
    "B: REL="*)
      rel_mask=$((16#${line#B: REL=}))
      ;;
    "")
      if [ -n "$handler" ]; then
        if [ $((ev_mask & 0x03)) -eq 3 ] && [ $((rel_mask & 0x03)) -eq 3 ]; then
          for h in $handler; do
            [[ "$h" == event* ]] && echo "/dev/input/$h" && return 0
          done
        fi
      fi
      handler=
      ev_mask=0
      rel_mask=0
      ;;
    esac
  done </proc/bus/input/devices
  return 1
}

# For killing the process later.
TEMPDIR='/tmp/movemouse'
PIDFILE=$TEMPDIR/PID
KEEPALIVEFILE=$TEMPDIR/KEEPALIVE_PID

# Keep sudo ticket alive so evemu-event doesn't re-prompt.
function keepalive() {
  while true; do
    sudo -v
    sleep 60
  done
}

function move() {
  # Don't do anything if mouse is manually being moved (Check every 2sec).
  if (! sudo inotifywait $dev -qq -t 2); then
    sudo evemu-event $dev --type EV_REL --code REL_X --value $1 &&
      sudo evemu-event $dev --type EV_REL --code REL_Y --value $1 --sync
  else
    sleep 30
  fi
}

function print_help() {
  echo "Usage: movemouse [--until=TIME]"
  echo "       movemouse -s"
  echo ""
  echo "Options:"
  echo "  -s              Stop moving the mouse."
  echo "  --until=TIME    Stop at given time (e.g. 14:30 or '30 minutes')."
  echo "  -h              Show this help text and exit."
  exit 0
}

function movemouse() {
  while true; do
    move 10 &&
      move -10
  done
}

PARSED=$(getopt -o 'sh' -l 'until:' -n 'movemouse' -- "$@")
if [ $? -ne 0 ]; then
  print_help
fi
eval set -- "$PARSED"

S=0
UNTIL=""

while true; do
  case "$1" in
  -s)
    S=1
    shift
    ;;
  --until)
    UNTIL="$2"
    shift 2
    ;;
  -h) print_help ;;
  --)
    shift
    break
    ;;
  *) print_help ;;
  esac
done

if [ "$S" == "1" ]; then
  if [ -f $PIDFILE ]; then
    kill $(cat $PIDFILE) 2>/dev/null
  fi
  if [ -f $KEEPALIVEFILE ]; then
    kill $(cat $KEEPALIVEFILE) 2>/dev/null
  fi
  rm -rf $TEMPDIR
else
  if [ -d $TEMPDIR ]; then
    if [ -z "$UNTIL" ]; then
      echo "movemouse is already running. Use -s to stop it first."
      exit 1

    fi
  fi

  if [ ! -d $TEMPDIR ]; then
    mkdir -p $TEMPDIR

    if [ -z "$dev" ]; then
      dev=$(detect_mouse)
    fi
    if [ -z "$dev" ]; then
      echo "Error: could not detect mouse device. Either set 'dev' at the top of"
      echo "the script, or use 'evemu-record' and 'evemu-describe' to find it."
      rm -rf $TEMPDIR
      exit 1
    fi

    sudo -v
    if [ $? -ne 0 ]; then
      echo "sudo authentication failed."
      rm -rf $TEMPDIR
      exit 1
    fi

    keepalive &
    echo $! >$KEEPALIVEFILE

    movemouse &
    echo $! >$PIDFILE
    echo $dev
  fi

  if [ -n "$UNTIL" ]; then
    target=$(date -d "$UNTIL" +%s 2>/dev/null)
    if [ $? -ne 0 ] || [ -z "$target" ]; then
      echo "Error: could not parse '$UNTIL'. Use formats like '14:30' or '30 minutes'."
      exit 1
    fi
    now=$(date +%s)
    [ $target -le $now ] && target=$((target + 86400))
    (
      sleep $((target - now))
      kill $(cat "$PIDFILE") $(cat "$KEEPALIVEFILE") 2>/dev/null
      rm -rf "$TEMPDIR"
      notify-send "$UNTIL reached. Movemouse stopped."
      exit 0
    ) &
  fi
fi
